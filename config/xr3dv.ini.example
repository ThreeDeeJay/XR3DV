; XR3DV runtime configuration
; Place this file next to xr3dv.dll  OR  next to your game's .exe
; (Game-local copy overrides only [Stereo] separation and convergence)

[Display]
; Per-eye render resolution
Width=1920
Height=1080

; Physical monitor refresh rate in Hz (used for D3D9 FSE device)
; Must match a mode listed in the xr3dv.log adapter mode list
MonitorRate=120

; Set HalfRate=true for shutter 3D displays (e.g. 120 Hz monitor, 60 fps per eye)
; XR apps will be timed at MonitorRate/2; D3D9 still runs at MonitorRate
HalfRate=false

[Stereo]
; Eye separation [0-100%]  — Ctrl+F3 decrease / Ctrl+F4 increase
Separation=50.0

; Convergence [0-25]       — Ctrl+F5 decrease / Ctrl+F6 increase
Convergence=5.000

; Save current values      — Ctrl+F7 (writes to game-local xr3dv.ini)

; Interpupillary distance in metres
IPD=0.064

[Debug]
; Log verbosity: 0=off 1=errors 2=info 3=verbose 4=trace
LogLevel=1
LogFile=xr3dv.log
