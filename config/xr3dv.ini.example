; XR3DV runtime configuration
; Global copy: place next to xr3dv.dll
; Per-game copy: place next to the game .exe — overrides [Stereo] sep/conv only

[Display]
Width=1920
Height=1080

; Physical monitor refresh rate Hz — used for D3D9 FSE device creation
MonitorRate=120

; HalfRate=true  → XR apps run at MonitorRate/2 fps (default: ON for shutter 3D)
; HalfRate=false → XR apps run at MonitorRate fps
HalfRate=true

[Stereo]
; Eye separation [0–100%]   Ctrl+F3 decrease / Ctrl+F4 increase (hold to repeat)
Separation=50.0

; Convergence [0–25]        Ctrl+F5 decrease / Ctrl+F6 increase (hold to repeat)
; This value is linked to the native 3D Vision convergence shown in its OSD.
Convergence=5.000

; Ctrl+F7 = save current values to the per-game xr3dv.ini

; Interpupillary distance in metres
IPD=0.064

[Debug]
; 0=off 1=errors 2=info 3=verbose 4=trace
LogLevel=1
LogFile=xr3dv.log
